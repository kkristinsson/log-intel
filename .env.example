# log-intel bootstrap — copy to .env or run ./install.sh
# Operational settings live in SQLite (Settings UI). .env seeds the DB on first run only.

# --- Docker host ports (compose only) ---
LOG_INTEL_HOST_SYSLOG_PORT=5516
LOG_INTEL_HOST_HTTP_PORT=9088
LOG_DIRS_HOST=/var/log

# --- Paths (bootstrap; DATA_DIR also wins from env when set in Docker) ---
DATA_DIR=./data
LOG_DIR=/var/log
# LOG_DIRS=/var/log,/var/log/remote

# --- Archive mounts (Docker compose, optional) ---
LOGGY_DATA_PATH=
NETSYSLOG_DATA_PATH=

# --- First-run secrets (install.sh generates FLASK_SECRET_KEY if missing) ---
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# --- Optional: Juniper Mist (seeded into Settings on first start) ---
# MIST_ENABLED=1
# MIST_API_KEY=
# MIST_BASE_URL=https://api.eu.mist.com/api/v1
# LOG_INTEL_LLM_SETUP=openai|grok|berget|ollama
# LOG_INTEL_LLM_API_KEY=
