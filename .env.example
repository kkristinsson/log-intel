# log-intel — copy to .env and edit. Or run ./install.sh (interactive).

# --- Docker host ports (compose only) ---
LOG_INTEL_HOST_SYSLOG_PORT=5516
LOG_INTEL_HOST_HTTP_PORT=9088
LOG_DIRS_HOST=/var/log

# --- Hub (network syslog) ---
LOG_INTEL_HTTP_HOST=0.0.0.0
LOG_INTEL_HTTP_PORT=9088
LOG_INTEL_SYSLOG_UDP_HOST=0.0.0.0
LOG_INTEL_SYSLOG_UDP_PORT=514
LOG_INTEL_SYSLOG_TCP_HOST=0.0.0.0
LOG_INTEL_SYSLOG_TCP_PORT=514
LOG_INTEL_QUEUE_MAXSIZE=50000
LOG_INTEL_RAW_TRUNCATE=2048
LOG_INTEL_DATA_DIR=./data
LOG_INTEL_SQLITE_PATH=./data/events.sqlite
LOG_INTEL_MAX_EVENTS=500000
LOG_INTEL_RETENTION_HOURS=0
LOG_INTEL_GEOIP_MMDB_PATH=./geoip/dbip-city-lite.mmdb
LOG_INTEL_LLM_ENABLED=0
LOG_INTEL_ANALYSIS_BATCH_SIZE=3
LOG_INTEL_ANALYSIS_INTERVAL_SEC=3600
LOG_INTEL_ALERT_MAX_PER_MINUTE=30
LOG_INTEL_ALERT_COOLDOWN_SEC=300

# --- File logs (syslogb core) ---
LOG_DIR=/var/log
# LOG_DIRS=/var/log,/var/log/remote
LOG_GLOB=*
LOG_RECURSIVE=0
DATA_DIR=./data
SCAN_INTERVAL_SEC=5
TAIL_BUFFER_SIZE=2000
TAIL_DEFAULT_ORDER=desc
LOG_SKIP_NAMES=wtmp,btmp,lastlog,faillog,README.logs
FILE_RECENT_BYTES=5242880
SEARCH_MAX_RESULTS=5000
SEARCH_MAX_BYTES_PER_FILE=52428800
SEARCH_CASE_SENSITIVE=0

# --- LLM (install.sh menu sets these) ---
# LLM_PROVIDER=ollama | openai | hybrid
LLM_ENABLED=1
LLM_PROVIDER=hybrid
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_CHAT_MODEL=
OLLAMA_BASE_URL=http://127.0.0.1:11435
OLLAMA_MODEL=qwen3.6:27b-q8_0
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SEC=600
OLLAMA_EMBED_TIMEOUT_SEC=600
OLLAMA_NUM_PREDICT=1024
OLLAMA_JSON_FORMAT=0
LOG_LINE_MAX_CHARS=4096
LLM_SKIP_LOW_LEVELS=1
LLM_MAX_FILE_BYTES=20971520
LLM_DIRECT_MAX_BYTES=524288
RAG_CHUNK_LINES=40
RAG_CHUNK_OVERLAP=8
RAG_TOP_K=12
RAG_MAX_LINES=200000
RAG_MAX_CHUNKS=1500
EMBED_BATCH_SIZE=8
EMBED_MAX_CHARS=4000
EMBED_LINE_MAX_CHARS=512
EMBED_MAX_RETRIES=4
RAG_QUERY=security anomalies errors failures authentication denials

# --- Auth (optional) ---
AUTH_ENABLED=0
FLASK_SECRET_KEY=change-me-to-a-long-random-string
LOCAL_AUTH_USERNAME=admin
LOCAL_AUTH_PASSWORD=

# --- Branding ---
APP_NAME=log-intel
BRAND_LOGO=branding/syslogb.jpg
BRAND_LOGO_LINK=
BRAND_TAGLINE=
COPYRIGHT_TEXT=Syslogb by Kristinsson Consulting

# --- Archive mounts (Docker compose, optional) ---
LOGGY_DATA_PATH=
NETSYSLOG_DATA_PATH=
