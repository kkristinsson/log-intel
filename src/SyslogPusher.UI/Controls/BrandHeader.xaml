<UserControl x:Class="SyslogPusher.UI.Controls.BrandHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Background="{StaticResource HeaderBrush}"
            CornerRadius="8"
            Padding="16,14"
            Margin="0,0,0,12">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Width="56" Height="56"
                    CornerRadius="10"
                    Background="White"
                    Padding="4"
                    VerticalAlignment="Center">
                <Image Source="/Assets/logo.png"
                       Stretch="Uniform"/>
            </Border>
            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding ProductName, ElementName=Root}"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource HeaderTextBrush}"/>
                <TextBlock Text="{Binding Subtitle, ElementName=Root}"
                           Margin="0,2,0,0"
                           Foreground="{StaticResource HeaderSubtextBrush}"/>
                <TextBlock Text="{Binding WrittenByLine, ElementName=Root}"
                           Margin="0,6,0,0"
                           FontSize="11"
                           Foreground="{StaticResource HeaderSubtextBrush}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
