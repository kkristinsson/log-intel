<Window x:Class="SyslogPusher.UI.Views.MaintenanceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SyslogPusher.UI.Controls"
        Title="Syslog Pusher Maintenance — Kristinsson Consulting AB"
        Height="560" Width="680"
        MinHeight="500" MinWidth="600"
        Icon="pack://application:,,,/SyslogPusher.UI;component/Assets/logo.png"
        Background="{StaticResource SurfaceBrush}"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="16">
        <controls:BrandFooter DockPanel.Dock="Bottom" Margin="0,12,0,0"/>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,8">
            <Button Content="Open configuration" Click="OnOpenConfiguration" Style="{StaticResource SecondaryButton}"/>
            <Button Content="Close" Click="OnClose" IsCancel="True" Style="{StaticResource SecondaryButton}"/>
        </StackPanel>

        <controls:BrandHeader DockPanel.Dock="Top"
                                Subtitle="Maintenance — upgrade or uninstall the installed service"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="StatusText"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16"
                           Foreground="{StaticResource MutedTextBrush}"/>

                <Border Background="White"
                        CornerRadius="8"
                        Padding="14"
                        Margin="0,0,0,12"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Upgrade"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#334155"
                                   LineHeight="22"
                                   Margin="0,0,0,12"
                                   Text="Point the installed service at this SyslogPusher.exe and restart it. Use when deploying a new build. Configuration is kept."/>
                        <Button x:Name="UpgradeButton"
                                Content="Upgrade"
                                Click="OnUpgrade"
                                HorizontalAlignment="Left"
                                MinWidth="120"/>
                    </StackPanel>
                </Border>

                <Border Background="White"
                        CornerRadius="8"
                        Padding="14"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Uninstall"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#334155"
                                   LineHeight="22"
                                   Margin="0,0,0,12"
                                   Text="Stop and remove the Syslog Pusher Windows service from this computer."/>
                        <CheckBox x:Name="RemoveConfigCheckBox"
                                  Content="Also remove configuration (%ProgramData%\SyslogPusher)"
                                  Margin="0,0,0,12"/>
                        <Button x:Name="UninstallButton"
                                Content="Uninstall"
                                Click="OnUninstall"
                                Style="{StaticResource DangerButton}"
                                HorizontalAlignment="Left"
                                MinWidth="120"/>
                    </StackPanel>
                </Border>

                <TextBlock TextWrapping="Wrap"
                           FontSize="12"
                           Foreground="{StaticResource MutedTextBrush}"
                           LineHeight="18"
                           Margin="0,12,0,0"
                           Text="To change settings only, run SyslogPusher.exe without administrator privileges, or click Open configuration."/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
